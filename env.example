# Copy to .env.local (gitignored). Melo provides values directly,
# never via chat. Confirm the service role key is the ROTATED key.
#
# Local dev: npm run dev → http://localhost:4343
# Supabase Auth redirect URLs must include:
#   http://localhost:4343/auth/callback
#   https://YOUR-PROJECT.vercel.app/auth/callback
#   https://thereflectivefootball.com/auth/callback (production)
#
# Google OAuth gap: the Google Cloud OAuth client may still list
# http://localhost:8595 as an authorized origin. Add
# http://localhost:4343 there and in Supabase before enabling Google sign-in.
NEXT_PUBLIC_SUPABASE_URL=https://ydffdymjgkpoogrgzjvy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Set to "true" once Google OAuth is configured in Supabase + env.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Random long string used to sign vote cookies and salt IP hashes.
VOTE_SECRET=
# YouTube Data API v3 (rolling view counter on /films). Optional until wired.
YOUTUBE_API_KEY=
# Defaults to TheReflectiveFootball if unset.
YOUTUBE_CHANNEL_HANDLE=TheReflectiveFootball
# Vercel Cron auth for /api/cron/refresh-channel-stats (generate: openssl rand -base64 32).
CRON_SECRET=
